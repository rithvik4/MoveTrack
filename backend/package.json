{
  "name": "movetrack-backend",
  "version": "1.0.0",
  "description": "MoveTrack Backend API - Modern Fitness Platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate": "node dist/utils/migrate.js",
    "seed": "node dist/utils/seed.js",
    "docker:build": "docker build -t movetrack-backend .",
    "docker:run": "docker run -p 3000:3000 movetrack-backend"
  },
  "keywords": [
    "fitness",
    "running",
    "walking",
    "gps",
    "tracking",
    "api",
    "express",
    "typescript"
  ],
  "author": "MoveTrack Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.11.0",
    "firebase-admin": "^11.11.0",
    "google-auth-library": "^9.4.1",
    "apple-signin-auth": "^1.0.0",
    "twilio": "^4.19.0",
    "nodemailer": "^6.9.7",
    "aws-sdk": "^2.1497.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.6",
    "razorpay": "^2.9.2",
    "stripe": "^14.9.0",
    "socket.io": "^4.6.1",
    "redis": "^4.6.11",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "uuid": "^9.0.1",
    "axios": "^1.6.2",
    "geo-distance": "^0.2.0",
    "@turf/turf": "^6.5.0",
    "geolib": "^3.3.4",
    "haversine-distance": "^1.2.1",
    "node-fetch": "^3.3.2",
    "openai": "^4.24.1",
    "@googlemaps/google-maps-services-js": "^3.3.42",
    "qrcode": "^1.5.3",
    "pdfkit": "^0.13.0",
    "csv-writer": "^1.6.0",
